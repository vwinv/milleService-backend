# URL publique HTTPS du backend (obligatoire pour PayDunya IPN)
# En production Render :
PUBLIC_API_URL=https://milleservice-backend-aacp.onrender.com

# Alternative explicite (même valeur que PUBLIC_API_URL en général)
# PAYDUNYA_CALLBACK_BASE_URL=https://milleservice-backend-aacp.onrender.com

# Ne pas utiliser localhost en production : PayDunya ne peut pas appeler
# http://localhost:3001/webhooks/paydunya depuis Internet.

# Clé Google Maps (Geocoding + Places Autocomplete + Routes). Activer sur Google Cloud :
# - Geocoding API
# - Places API (Autocomplete, Text Search, Place Details)
# - Routes API (itinéraires)
GOOGLE_MAPS_API_KEY=
